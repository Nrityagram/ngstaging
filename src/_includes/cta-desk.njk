<script>
	(function () {
		var items = Array.from(document.querySelectorAll('.cta-desk'));
		if (items.length <= 1) {
			if (items.length === 1) {
				items[0].style.animation = 'none';
				items[0].style.opacity = '1';
			}
			return;
		}

		var current = 0;
		var displayDuration = 5000; // ms each CTA stays visible

		// Build dots
		var dotsContainer = document.getElementById('cta-dots');
		items.forEach(function (_, i) {
			var dot = document.createElement('button');
			dot.className = 'cta-dot' + (
				i === 0
				? ' cta-dot--active'
				: '');
			dot.setAttribute('aria-label', 'Go to announcement ' + (
			i + 1));
			dot.addEventListener('click', function () {
				show(i);
			});
			dotsContainer.appendChild(dot);
		});

		// Hide all CTAs except the first; disable their entry animation
		items.forEach(function (el, i) {
			if (i !== 0) {
				el.style.animation = 'none';
				el.style.display = 'none';
			}
		});

		function isLandscape() {
			return window
				.matchMedia('(orientation: landscape)')
				.matches;
		}

		function show(index) {
			items.forEach(function (el, i) {
				el.style.animation = 'none';
				el.style.display = i === index && isLandscape()
					? 'flex'
					: 'none';
				el.style.opacity = i === index
					? '1'
					: '0';
			});
			var dots = dotsContainer.querySelectorAll('.cta-dot');
			dots.forEach(function (dot, i) {
				dot
					.classList
					.toggle('cta-dot--active', i === index);
			});
			current = index;
		}

		function advance() {
			show((current + 1) % items.length);
			setTimeout(advance, displayDuration);
		}

		// Wait for the initial fade-in animation to finish, then start cycling
		var initialAnimDuration = 4000; // matches 1s delay + 3s animation
		setTimeout(advance, initialAnimDuration + displayDuration);
	})();
</script>